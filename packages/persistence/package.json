{
  "name": "@reaatech/circuit-breaker-persistence",
  "version": "0.1.0",
  "description": "Persistence adapters for circuit-breaker-agents",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/circuit-breaker-agents.git",
    "directory": "packages/persistence"
  },
  "homepage": "https://github.com/reaatech/circuit-breaker-agents/tree/main/packages/persistence#readme",
  "bugs": {
    "url": "https://github.com/reaatech/circuit-breaker-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/firestore": {
      "types": "./dist/adapters/firestore.d.ts",
      "import": "./dist/adapters/firestore.js",
      "require": "./dist/adapters/firestore.cjs"
    },
    "./adapters/dynamodb": {
      "types": "./dist/adapters/dynamodb.d.ts",
      "import": "./dist/adapters/dynamodb.js",
      "require": "./dist/adapters/dynamodb.cjs"
    },
    "./adapters/redis": {
      "types": "./dist/adapters/redis.d.ts",
      "import": "./dist/adapters/redis.js",
      "require": "./dist/adapters/redis.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/util-dynamodb": "^3.500.0",
    "@google-cloud/firestore": "^7.0.0",
    "ioredis": "^5.3.2"
  },
  "peerDependenciesMeta": {
    "@google-cloud/firestore": {
      "optional": true
    },
    "@aws-sdk/client-dynamodb": {
      "optional": true
    },
    "@aws-sdk/util-dynamodb": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1035.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@google-cloud/firestore": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ioredis": "^5.10.1",
    "tsup": "^8.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@reaatech/circuit-breaker-core": "workspace:*"
  }
}
