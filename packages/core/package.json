{
  "name": "circuit-breaker-core",
  "version": "0.1.0",
  "description": "Core circuit breaker logic for agent systems",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/circuit-breaker-agents.git"
  },
  "homepage": "https://github.com/reaatech/circuit-breaker-agents#readme",
  "bugs": {
    "url": "https://github.com/reaatech/circuit-breaker-agents/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "zod": "^3.22.4"
  },
  "dependencies": {
    "zod": "^3.22.4"
  }
}
