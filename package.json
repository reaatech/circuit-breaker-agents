{
  "name": "circuit-breaker-agents",
  "version": "0.1.0",
  "description": "Circuit breaker library for agent-to-tool and agent-to-agent communication",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/circuit-breaker-agents.git"
  },
  "homepage": "https://github.com/reaatech/circuit-breaker-agents#readme",
  "bugs": {
    "url": "https://github.com/reaatech/circuit-breaker-agents/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,md,json,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,md,json,yaml}\"",
    "type-check": "tsc --noEmit",
    "check": "pnpm lint && pnpm type-check && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@types/node": ">=18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "turbo": "^2.9.6",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.14.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
